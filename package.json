{
  "name": "poc-banking-chat",
  "version": "2.0.0",
  "private": true,
  "description": "Enterprise Chat Banking Application - Microservices Architecture with AI Orchestration",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "//-- DEVELOPMENT --//": "",
    "dev": "concurrently -n 'gateway,chat,banking,nlu,mcp,ai' -c 'blue,green,yellow,magenta,cyan,red' 'npm run dev:gateway' 'npm run dev:chat' 'npm run dev:banking' 'npm run dev:nlu' 'npm run dev:mcp' 'npm run dev:ai'",
    "dev:frontend": "npm run dev -w services/frontend",
    "dev:gateway": "npm run dev -w services/api-gateway",
    "dev:chat": "npm run dev -w services/chat-backend",
    "dev:banking": "npm run dev -w services/banking-service",
    "dev:nlu": "npm run dev -w services/nlu-service",
    "dev:mcp": "npm run dev -w services/mcp-service",
    "dev:ai": "npm run dev -w services/ai-orchestrator",
    "dev:agent": "npm run dev -w services/agent-ui",

    "//-- PRODUCTION --//": "",
    "start": "./scripts/start-all.sh",
    "stop": "./scripts/stop-all.sh",
    "restart": "./scripts/stop-all.sh && ./scripts/start-all.sh",
    "start:frontend": "npm run start -w services/frontend",
    "start:gateway": "npm run start -w services/api-gateway",
    "start:chat": "npm run start -w services/chat-backend",
    "start:banking": "npm run start -w services/banking-service",
    "start:nlu": "npm run start -w services/nlu-service",
    "start:mcp": "npm run start -w services/mcp-service",
    "start:ai": "npm run start -w services/ai-orchestrator",
    "start:agent": "npm run start -w services/agent-ui",

    "//-- BUILD --//": "",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build -w services/frontend",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",

    "//-- TESTING --//": "",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "./scripts/test-integration.sh",
    "test:e2e": "./scripts/test-e2e.sh",
    "health": "./scripts/health-check.sh",

    "//-- DATABASE --//": "",
    "db:setup": "./scripts/db-setup.sh",
    "db:migrate": "npm run db:migrate -w services/banking-service",
    "db:seed": "npm run db:seed -w services/banking-service",
    "db:reset": "npm run db:reset -w services/banking-service",

    "//-- DOCKER --//": "",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f",
    "docker:build": "docker-compose -f docker/docker-compose.yml build",
    "docker:full": "docker-compose -f docker/docker-compose.full.yml up -d",

    "//-- UTILITIES --//": "",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "validate": "./scripts/validate-env.sh",
    "postinstall": "npm run validate || true"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kishorekota-dev/map_demo.git"
  },
  "keywords": [
    "banking",
    "chatbot",
    "microservices",
    "ai",
    "langgraph",
    "mcp",
    "dialogflow",
    "react",
    "nodejs"
  ],
  "author": "POC Development Team",
  "license": "MIT"
}

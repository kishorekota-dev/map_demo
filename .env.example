# POC Banking Chat - Environment Configuration
# Copy this file to .env.development for local development

# ===========================================
# General
# ===========================================
NODE_ENV=development
LOG_LEVEL=debug

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/poc_banking
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=poc_banking

# ===========================================
# Redis (for sessions/caching)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Security
# ===========================================
JWT_SECRET=change-this-to-a-secure-secret-in-production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10

# ===========================================
# Service URLs (for inter-service communication)
# ===========================================
API_GATEWAY_URL=http://localhost:3001
CHAT_BACKEND_URL=http://localhost:3006
BANKING_SERVICE_URL=http://localhost:3005
NLU_SERVICE_URL=http://localhost:3003
MCP_SERVICE_URL=http://localhost:3004
AI_ORCHESTRATOR_URL=http://localhost:3007

# ===========================================
# AI Services (Optional)
# ===========================================
# OpenAI - Required for AI Orchestrator
OPENAI_API_KEY=your-openai-api-key

# DialogFlow - Required for NLU Service
DIALOGFLOW_PROJECT_ID=your-dialogflow-project-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/dialogflow.json

# ===========================================
# CORS
# ===========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
